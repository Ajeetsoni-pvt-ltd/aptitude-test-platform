# ═══════════════════════════════════════════════════════════════
# ApptitudeTest.live — Production Environment Variables
# Copy this to .env.production on your VPS and fill in values
# Location on VPS: /opt/aptitude-test-platform/.env.production
# ═══════════════════════════════════════════════════════════════

# ─── App Config ────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── Database (MongoDB Atlas) ─────────────────────────────────
# Get from: MongoDB Atlas → Database → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/aptitude_test?retryWrites=true&w=majority

# ─── JWT Authentication ──────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<generate-a-64-byte-hex-secret>
JWT_EXPIRE=7d

# ─── Client URL (for email verification links) ───────────────
# IMPORTANT: This is used to build verification/reset links in emails
# Must be the EXACT frontend URL users visit (with https, no trailing slash)
CLIENT_URL=https://aptitudetest.site

# ─── CORS Allowed Origins ────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Include both with and without www
CORS_ORIGINS=https://aptitudetest.site,https://www.aptitudetest.site

# ─── SMTP Email (Gmail App Password) ─────────────────────────
# Gmail App Password: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ajeetshroff@gmail.com
SMTP_PASS=<your-gmail-app-password>
EMAIL_FROM="ApptitudeTest.live" <ajeetshroff@gmail.com>

# ─── Gemini AI ────────────────────────────────────────────────
GEMINI_API_KEY=<your-gemini-api-key>

# ─── Server Public URL ───────────────────────────────────────
PUBLIC_SERVER_URL=https://aptitudetest.site

# ─── Docker / CI-CD ──────────────────────────────────────────
GHCR_OWNER=ajeetsoni-pvt-ltd
IMAGE_TAG=latest