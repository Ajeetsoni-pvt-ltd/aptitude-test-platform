# ─────────────────────────────────────
# App Config
# ─────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─────────────────────────────────────
# Database
# ─────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/aptitude_test

# ─────────────────────────────────────
# Auth
# ─────────────────────────────────────
JWT_SECRET=your-super-strong-secret-key-change-this

# ─────────────────────────────────────
# Client (CORS)
# IMPORTANT: HTTP + HTTPS dono allow karo (CORS fix)
# ─────────────────────────────────────
CLIENT_URL=http://localhost:5173,http://aptitudetest.site,https://aptitudetest.site

# ─────────────────────────────────────
# Server Public URL
# ─────────────────────────────────────
PUBLIC_SERVER_URL=https://aptitudetest.site

# ─────────────────────────────────────
# Cloudinary (optional - for image upload)
# ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────
# Docker / CI-CD
# ─────────────────────────────────────
GHCR_OWNER=ajeetsoni-pvt-ltd
IMAGE_TAG=latest